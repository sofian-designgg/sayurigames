# ===========================================
# SAYURI GAMES – Variables d'environnement
# ===========================================
# Copie ce fichier en .env et remplis les valeurs.
# Sur Vercel : définir les variables du SITE (pas le bot).
# Sur Railway : définir les variables du BOT uniquement.
# ===========================================

# ---------- SITE (Vercel) ----------
# URL publique du site (ex. https://sayuri-games.vercel.app).
# Obligatoire pour que la connexion Discord redirige au bon endroit.
NEXTAUTH_URL=https://ton-projet.vercel.app

# Secret pour signer les sessions NextAuth. Génère-en un avec : openssl rand -base64 32
NEXTAUTH_SECRET=ta-cle-secrete-random

# Identifiants de l’application Discord (Portail développeur Discord → ton application → OAuth2).
# Utilisés pour que les visiteurs se connectent au site avec leur compte Discord.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Connexion à la base MongoDB (Atlas, Railway, etc.).
# Le site stocke ici : utilisateurs, Sayucoins, classement, rôles en attente (roulette).
# Ex. : mongodb+srv://user:pass@cluster.mongodb.net/sayurigames
MONGO_URL=

# ---------- BOT (Railway ou autre) ----------
# Le bot n’utilise pas MongoDB : il appelle le site (SITE_URL) pour classement / argent / rôles.
# Token du bot Discord (Portail développeur → Bot → Reset Token / Copy).
DISCORD_BOT_TOKEN=

# ID du serveur Discord (clic droit sur le serveur → Copier l’identifiant).
DISCORD_GUILD_ID=

# ID du salon où le bot envoie le classement toutes les heures (clic droit sur le salon → Copier l’identifiant).
DISCORD_RANKING_CHANNEL_ID=

# URL du site déployé (la même que NEXTAUTH_URL). Le bot appelle les APIs du site (classement, argent, rôles à attribuer).
SITE_URL=https://ton-projet.vercel.app

# Secret partagé entre le site et le bot. Le bot l’envoie en en-tête pour appeler les routes protégées (solde d’un user, récupérer les rôles gagnés).
# Doit être identique sur Vercel et sur Railway (ou le bot ne pourra pas récupérer les rôles ni les soldes).
SAYURI_BOT_SECRET=memesecret-que-tu-choisis
